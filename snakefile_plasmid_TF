configfile: 'config.yml'

rule all:
    input:
        expand('data/abricate/amr/{sample}.tab',sample=config['samples']),
        expand('data/prokka/plasmid/{sample}/{sample}.tsv',sample=config['samples']),
        expand('data/swissprot/{sample}.tsv',sample=config['samples'])
        expand('data/deeptfactor/{sample}/prediction_results.txt',sample=config['samples'])

rule plasmid_amr:
    input:
        'data/plasmid_contigs/{sample}.fasta'
    output:
        'data/abricate/amr/{sample}.tab'
    conda:
        'env/abricate.yml'
    threads: 4
    shell:
        'abricate {input} > {output}'

rule prokka:
    input:
        'data/plasmid_contigs/{sample}.fasta'
    output:
        folder=directory('data/prokka/plasmid/{sample}'),
        tsv='data/prokka/plasmid/{sample}/{sample}.tsv',
        ffn='data/prokka/plasmid/{sample}/{sample}.ffn',
    conda:
        'env/prokka.yml'
    threads: 8
    shell:
        'prokka --outdir {output.folder} --prefix {wildcards.sample} {input} --force'
    
rule wget_uniprot:
    input:

    output:
        temp('bin/swissprot/uniprot_sprot.fasta')
    params:
        'https://ftp.uniprot.org/pub/databases/uniprot/current_release/knowledgebase/complete/uniprot_sprot.fasta.gz'
    threads: 2 
    shell:
        'wget {params} -P bin/swissprot && '
        'gunzip {output}.gz'

rule makeblastdb:
    input:
        uniprot_fasta='bin/swissprot/uniprot_sprot.fasta'
    output:
        phr='bin/swissprot/swissprot.phr',
        pin='bin/swissprot/swissprot.pin',
        psq='bin/swissprot/swissprot.psq'
    conda:
        'env/blast.yml'
    params:
        db='bin/swissprot/swissprot'
    threads: 4        
    shell:
        'makeblastdb -dbtype prot -in {input.uniprot_fasta} -out {params.db}'

rule swissprot_blastx:
    input:
        ffn='data/prokka/plasmid/{sample}/{sample}.ffn',
        phr='bin/swissprot/swissprot.phr',
        pin='bin/swissprot/swissprot.pin',
        psq='bin/swissprot/swissprot.psq'
    output:
        'swissprot/blastx/{sample}.tsv'
    conda:
        'env/blast.yml'
    params:
        db='bin/swissprot/swissprot',
        outfmt='6',
        evalue='0.1',
        max_hsps='1'
        max_seqs='10'
    threads: 4
    shell:
        'blastx -query {input.ffn} -db {params.db}'
        ' -out {output} -outfmt {params.outfmt} -evalue {params.evalue} -max_hsps {params.max_hsps} -max_target_seqs {params.max_seqs} -num_threads {threads}'

rule uniprot_query:
    input:
        'data/swissprot/blastx/{sample}.tsv'
    output:
        'data/swissprot/query/{sample}.tsv'
    threads: 2
    script:
        'scripts/uniprot_query.py'

rule keep_best:
    input:
        'data/swissprot/query/{sample}.tsv'
    output:
        'data/swissprot/{sample}.tsv'
    threads: 2
    script:
        'scripts/sprot_keep_best.py'

rule find_TF_sprot:
    input:
        'data/swissprot/{sample}.tsv'
    output:
        'data/swissprot/TF/{sample}.tsv'
    threads: 2
    script:
        'scripts/find_TF.py'

rule deeptfactor:
    input:
        'data/prokka_plasmid/{sample}/{sample}.faa'
    output:
        folder = directory('data/deeptfactor/{sample}/'),
        txt = 'data/deeptfactor/{sample}/prediction_results.txt'
    conda:
        'env/deeptfactor.yml'
    params:
        'scripts/trained_model/DeepTFactor_ckpt.pt'
    threads: 2
    shell:
        'python3 scripts/tf_running.py -i {input} -o {output.folder} -ckpt {params} -g cpu'